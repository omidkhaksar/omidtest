# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: restrict bot to your Telegram user ID (from @userinfobot)
TELEGRAM_ALLOWED_USER_IDS=

# Dashboard URL shown in bot replies
DASHBOARD_URL=http://localhost:8000

# Server
HOST=0.0.0.0
PORT=8000

# SQLite path (use /app/data in Docker, /tmp on Vercel)
DATABASE_URL=sqlite:///./house_hunt.db

# Process mode: all | api | bot
RUN_MODE=all

# Telegram on Vercel: webhook | polling | auto (auto = webhook on Vercel)
TELEGRAM_MODE=auto

# Random secret for Telegram webhook (required on Vercel)
# Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Postgres for Vercel (from Neon). Local dev can use SQLite above.
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
